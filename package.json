{
  "name": "floating-spheres",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "npx biome lint .",
    "lint:fix": "npx biome lint . --write",
    "lint:unsafe-fix": "npx biome lint . --write --unsafe",
    "format": "npx biome format .",
    "format:fix": "npx biome format . --write",
    "check": "npx biome check .",
    "check:fix": "npx biome check . --write",
    "check:unsafe-fix": "npx biome check . --write --unsafe",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  }
}
